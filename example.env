NODE_ENV=development
PORT=3000
APP_NAME=YouOme Backend
# Used by infra/docker-compose.prod.yml (compose ${VAR} substitution, not
# read directly by the app) - the public origin, e.g. https://app.youome.de
APP_URL=
JWT_SECRET=replace-with-a-long-random-secret-for-access-tokens
JWT_REFRESH_SECRET=replace-with-a-long-random-secret-for-refresh-tokens
BYPASS_AUTH=true
SYSTEM_ADMIN_EMAILS=sysadmin@example.com
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# MongoDB Authentication
MONGO_URI=mongodb://localhost:27017/youome-dev
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_AUTH_SOURCE=admin
# Used by infra/docker-compose.prod.yml (compose ${VAR} substitution) to
# build the production MONGODB_URI and seed the Mongo container's initial db
MONGO_DB=youome

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password
REDIS_DB=0

# CORS - comma-separated origins (only used in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:4173,http://127.0.0.1:5173