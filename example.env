NODE_ENV=development
PORT=3000
APP_NAME=YouOme Backend
# The public frontend origin, e.g. https://app.youome.de - used both by
# infra/docker-compose.prod.yml (compose ${VAR} substitution) and read
# directly by the app to build email verification/password reset links.
# Defaults to http://localhost:5173 (the Vite dev server) if unset.
APP_URL=
JWT_SECRET=replace-with-a-long-random-secret-for-access-tokens
JWT_REFRESH_SECRET=replace-with-a-long-random-secret-for-refresh-tokens
# Refresh token lifetime; REMEMBER_ME is used when login requests rememberMe=true
REFRESH_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_REMEMBER_ME=60d
BYPASS_AUTH=true
SYSTEM_ADMIN_EMAILS=sysadmin@example.com
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# MongoDB Authentication
MONGO_URI=mongodb://localhost:27017/youome-dev
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_AUTH_SOURCE=admin
# Used by infra/docker-compose.prod.yml (compose ${VAR} substitution) to
# build the production MONGODB_URI and seed the Mongo container's initial db
MONGO_DB=youome

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password
REDIS_DB=0

# CORS - comma-separated origins (only used in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:4173,http://127.0.0.1:5173

# Garage (S3-compatible object storage) - avatars/group images.
# GARAGE_ENDPOINT below is the host-facing address, for running the backend
# directly via `npm run dev` against the dockerized garage/mongo/redis (same
# pattern as MONGO_URI/REDIS_HOST above). docker-compose.yml overrides this to
# the internal docker-network address (http://garage:3900) when the backend
# itself also runs inside that compose stack.
# GARAGE_ACCESS_KEY_ID/GARAGE_SECRET_ACCESS_KEY come from `garage key create`
# (see backend/garage/init-garage.ps1 for local dev, infra/deploy/init-garage.sh
# for prod) - there is no usable default for these two.
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_REGION=garage
GARAGE_BUCKET=avatars
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=

# email-service (../email-service, standalone Resend wrapper) - EMAIL_SERVICE_API_KEY
# must match that service's own EMAIL_SERVICE_API_KEY (its .env.example).
EMAIL_SERVICE_URL=http://localhost:4000
EMAIL_SERVICE_API_KEY=replace-with-a-long-random-secret
# RESEND_API_KEY/RESEND_FROM_DEFAULT are not read by this app - they're only here because
# infra/docker-compose.prod.yml uses backend/.env as its single env-file and substitutes
# them into the email-service container. Leave RESEND_API_KEY unset to run email-service
# in dry-run mode (logs instead of sending).
RESEND_API_KEY=
RESEND_FROM_DEFAULT=no-reply@contact.youome.de